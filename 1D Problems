1.Climbing Stairs.
-> Memoization
class Solution {
    public int fun(int n , int[]dp){
        if(n <= 1){
            return 1;
        }
        if(dp[n] != -1){
            return dp[n];
        }
        dp[n] = fun(n-1 , dp) + fun(n-2 , dp);
        return dp[n];
    }
    public int climbStairs(int n) {
        int []dp = new int[n+1];
        Arrays.fill(dp , -1);
        dp[n] = fun(n , dp);
        return dp[n];
    }
}
