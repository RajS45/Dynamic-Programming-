3.Fromg Jump with k dsitance 
->By Recursion.
class Solution {
    public int func(int[] heights, int k, int ind) {
        if (ind == 0) return 0;
        int minStep = Integer.MAX_VALUE;
        for (int i = 1; i <= k; i++) {
            if (ind - i >= 0) {
                int jump = func(heights, k, ind - i) 
                           + Math.abs(heights[ind] - heights[ind - i]);
                minStep = Math.min(minStep, jump);
            }
        }
        return minStep;
    }
    public int frogJump(int[] heights, int k) {
        int n = heights.length;
        return func(heights, k, n - 1);
    }
}
