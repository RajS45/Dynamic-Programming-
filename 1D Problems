class Solution {
    public int func(int[] heights, int k, int ind , int []dp) {
        if (ind == 0) return 0;
        if(dp[ind] != -1) return dp[ind];
        int minStep = Integer.MAX_VALUE;
        for (int i = 1; i <= k; i++) {
            if (ind - i >= 0) {
                int jump = func(heights, k, ind - i,dp) 
                           + Math.abs(heights[ind] - heights[ind - i]);
                minStep = Math.min(minStep, jump);
            }
        }
        dp[ind] = minStep;
        return dp[ind];
    }
    public int frogJump(int[] heights, int k) {
        int n = heights.length;
        int []dp = new int[n+1];
        Arrays.fill(dp , -1);
        return func(heights, k, n - 1,dp);
    }
}
-> Tabulation.
class Solution {
    public int frogJump(int[] heights, int k) {
        int n = heights.length;
        int []dp = new int[n+1];
        Arrays.fill(dp , -1);
        dp[0] = 0;
        for(int i = 1;i<n;i++){
            int minStep = Integer.MAX_VALUE;
            for(int j=1;j<=k;j++){
                if(i-j >= 0){
                    int prevInd = (i-j) % k;
                    int jump = dp[prevInd] + Math.abs(heights[i] - heights[i-j]);
                    minStep = Math.min(minStep , jump);
                }
            }
            dp[i % k] = minStep;
        }
        return dp[(n - 1)%k];
    }
}
4.Maximum Adjacent sum 
-> Memoization
class Solution {
    public int fun(int ind , int[]nums , int []dp){
        if(ind == 0) return nums[ind];
        if(ind < 0) return 0;
        if(dp[ind] != -1) return dp[ind];
        int pick = nums[ind] + fun(ind - 2 , nums , dp);
        int notPick = 0 + fun(ind-1 , nums,dp);
        return dp[ind] = Math.max(pick , notPick);
    }
    public int nonAdjacent(int[] nums) {
        int n = nums.length;
        int []dp = new int[n+1];
        Arrays.fill(dp , -1);
        return fun(n-1 , nums , dp);
    }
}
->Tabulation
class Solution {
    public int nonAdjacent(int[] nums) {
        int n = nums.length;
        if (n == 0) return 0;
        if (n == 1) return nums[0];
        int[] dp = new int[n];
        dp[0] = nums[0];
        dp[1] = Math.max(nums[0], nums[1]);
        for (int i = 2; i < n; i++) {
            int pick = nums[i] + dp[i - 2];  
            int nonPick = dp[i - 1];
            dp[i] = Math.max(pick, nonPick);
        }
        return dp[n - 1];
    }
}
