class Solution {
    public int fun(int[] nums){
        int n = nums.length;
        if(n == 0) return 0;
        if(n == 1) return nums[0];
        int[] dp = new int[n];
        dp[0] = nums[0];
        for(int i=1;i<n;i++){
            int pick = nums[i];
            if(i > 1) pick += dp[i-2];
            int nonPick = dp[i-1];
            dp[i] = Math.max(pick , nonPick);
        }
        return dp[n-1];
    }
    public int houseRobber(int[] money) {
        int n = money.length;
        if(n == 1) return money[0];
        int[] arr1 = Arrays.copyOfRange(money, 1, n);
        int[] arr2 = Arrays.copyOfRange(money, 0, n-1);
        int ans1 = fun(arr1);
        int ans2 = fun(arr2);
        return Math.max(ans1 , ans2);
    }
}

